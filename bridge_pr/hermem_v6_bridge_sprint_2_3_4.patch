From 197bd40167b6e7ecd50b17845bf54406a9a7493c Mon Sep 17 00:00:00 2001
From: Oliver <oliver@example.com>
Date: Thu, 11 Jun 2026 22:27:18 +0800
Subject: [PATCH 2/3] fix(hermem-bridge): _ensure_impl add config module to
 _impl_cache

Bug fix: `_ensure_impl()` imported database/embedding/vectorstore/retrieval
modules but did NOT register config in `_impl_cache`. Any code path
calling `impl['config']` (e.g. reading constants) would raise KeyError.

This was latent until the cron prompt alignment work added a feature that
reads `impl['config'].STATS_SCHEMA_VERSION` from the bridge. Caught at
2026-06-11 21:38 when hermem_stats() handle_tool_call returned
`hermem_stats failed: 'config'`.

Fix: import + register config alongside the other modules.
---
 plugins/memory/hermem/__init__.py | 3 ++-
 1 file changed, 2 insertions(+), 1 deletion(-)

diff --git a/plugins/memory/hermem/__init__.py b/plugins/memory/hermem/__init__.py
index 68129e4e0..97e782dde 100644
--- a/plugins/memory/hermem/__init__.py
+++ b/plugins/memory/hermem/__init__.py
@@ -54,7 +54,7 @@ def _ensure_impl():
         sys.path.insert(0, impl_path)
 
     try:
-        from impl import database, embedding, vectorstore, retrieval
+        from impl import database, embedding, vectorstore, retrieval, config
         from impl.database import init_db
         from impl.vectorstore import init_vectorstore
 
@@ -66,6 +66,7 @@ def _ensure_impl():
         _impl_cache["embedding"] = embedding
         _impl_cache["vectorstore"] = vectorstore
         _impl_cache["retrieval"] = retrieval
+        _impl_cache["config"] = config
         # V6 Sprint 2: predictive recall (predictor 模块)
         try:
             from impl import predictor
-- 
